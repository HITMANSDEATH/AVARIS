# AI API Keys
# Get your Gemini API key from: https://makersuite.google.com/app/apikey
# Example: GEMINI_API_KEY="AIzaSyBxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GEMINIV_API_KEY=""
GEMINI_API_KEY=""

# Hardware IPs
ESP32_IP="YOUR_ESP32_IP"
ESP32_SENSOR_IP="192.168.1.42"  #change ESP32 sensor server IP
ESP32_CAM_IP="192.168.1.100"    #idts to change ESP32 camera IP
ESP32CAM_STREAM_URL="http://YOUR_CAMERA_IP/stream"
CAMERA_STREAM_URL="http://ESP32CAM_IP/stream"

# Sensor Polling Configuration
SENSOR_POLL_INTERVAL="5"  # Poll ESP32 every 5 seconds

# Database
DATABASE_PATH="./database/environment_monitor.db"
